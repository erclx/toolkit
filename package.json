{
  "name": "toolkit",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Infrastructure and quality tooling for developer workflows",
  "bin": {
    "aitk": "./scripts/manage-aitk.sh"
  },
  "scripts": {
    "check:spell": "cspell '**' --no-progress --color --show-context",
    "format": "prettier --write --ignore-path .gitignore . && shfmt --write --indent 2 scripts/ tooling/",
    "check:format": "prettier --check --ignore-path .gitignore . && shfmt --diff --indent 2 scripts/ tooling/",
    "check:shell": "find scripts tooling -name '*.sh' -exec shellcheck --severity=warning {} +",
    "prepare": "husky",
    "check": "./scripts/core/verify.sh",
    "update": "./scripts/core/update.sh",
    "clean": "./scripts/core/clean.sh",
    "snapshot": "./scripts/core/snapshot.sh",
    "aitk:sandbox": "aitk sandbox",
    "aitk:sandbox:reset": "aitk sandbox reset"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "cspell": "^8.17.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
